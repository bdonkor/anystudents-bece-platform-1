# ANYSTUDENTS BECE PLATFORM - ENVIRONMENT VARIABLES EXAMPLE
# Copy this file to .env and fill in your actual values
# NEVER commit your real .env file to version control

# --- SUPABASE ---
# Get these from your Supabase Dashboard > Project Settings > API
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# --- ANTHROPIC CLAUDE API ---
# Get this from console.anthropic.com
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key

# --- PAYSTACK ---
# Get these from your Paystack Dashboard > Settings > API Keys & Webhooks
VITE_PAYSTACK_PUBLIC_KEY=your_paystack_public_key
PAYSTACK_SECRET_KEY=your_paystack_secret_key

# --- PLATFORM SETTINGS ---
VITE_APP_URL=https://mockexams.anystudents.com
VITE_SUBSCRIPTION_AMOUNT=10000
# Amount in kobo/pesewas - 10000 = GH₵100

# --- FACEBOOK PIXEL ---
VITE_FACEBOOK_PIXEL_ID=your_facebook_pixel_id_here
